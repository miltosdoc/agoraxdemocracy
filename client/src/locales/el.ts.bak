   529|  'walkthrough.step7_name': 'Επαληθευμένο Ψηφοδέλτιο',
'walkthrough.hiw_hero_title': 'Η Διαδικασία Διαβούλευσης',
  'walkthrough.hiw_hero_subtitle': 'Η AgoraX δεν είναι απλά μια πλατφόρμα ψηφοφοριών. Είναι ένα πλήρες σύστημα διαβουλευτικής δημοκρατίας, σχεδιασμένο για να μετατρέπει την αυθόρμητη συμμετοχή σε θεσμοθετημένες αποφάσεις — με διαφάνεια, ποιότητα και νομιμοποίηση.',
  'walkthrough.hiw_phase_label': 'ΦΑΣΗ',
  'walkthrough.hiw_different_title': 'Τι Κάνει την AgoraX Διαφορετική',
  'walkthrough.hiw_innovation1_title': 'Διαβούλευση, Όχι Μόνο Ψηφοφορία',
  'walkthrough.hiw_innovation1_desc': 'Οι προτάσεις δεν τίθενται απευθείας σε ψηφοφορία. Περνούν από φάσεις τροπολογίας, αιτιολόγησης και σύνθεσης — ώστε το τελικό κείμενο να είναι καλύτερο από την αρχική ιδέα.',
  'walkthrough.hiw_innovation2_title': 'Κληρωτά Σώματα, Όχι Ελίτ',
  'walkthrough.hiw_innovation2_desc': 'Η σύνθεση του τελικού κειμένου ανατίθεται σε τυχαία επιλεγμένους πολίτες, όχι σε ειδικούς ή πολιτικούς. Αυτό εξασφαλίζει αντιπροσωπευτικότητα χωρίς διορισμό.',
  'walkthrough.hiw_innovation3_title': 'Επαληθευμένη Ταυτότητα',
  'walkthrough.hiw_innovation3_desc': 'Χάρη στην ενσωμάτωση με Gov.gr, κάθε ψήφος επαληθεύεται ως προερχόμενη από πραγματικό πολίτη — αντιμετωπίζοντας το πρόβλημα των bots και των πολλαπλών λογαριασμών.',
  'walkthrough.hiw_cta_title': 'Ξεκινήστε Τώρα',
  'walkthrough.hiw_cta_desc': 'Είτε θέλετε να υποβάλλετε μια πρόταση, να συμμετάσχετε σε μια κοινότητα, είτε απλά να μάθετε περισσότερα — η πλατφόρμα είναι ανοιχτή.',
  'walkthrough.hiw_cta_walkthrough': 'Δείτε το Διαδραστικό Walkthrough',
  'walkthrough.hiw_cta_register': 'Δημιουργία Λογαριασμού',
  'walkthrough.hiw_example_label': 'Ενδεικτικό παράδειγμα:',
  'walkthrough.hiw_example_question': 'Ερώτημα:',
  'walkthrough.hiw_example_question_text': 'Πώς μπορούμε να μειώσουμε την κυκλοφοριακή συμφόρηση στο κέντρο της Αθήνας;',
  'walkthrough.hiw_example_solution': 'Λύση:',
  'walkthrough.hiw_example_solution_text': 'Δημιουργία ζώνης χαμηλών εκπομπών (LEZ) με δωρεάν δημόσια συγκοινωνία και παροχώρηση ηλεκτρικών οχημάτων.',
  'walkthrough.hiw_score_structure': 'Δομή',
  'walkthrough.hiw_score_specificity': 'Συγκεκριμ.',
  'walkthrough.hiw_score_feasibility': 'Εφικτότητα',
