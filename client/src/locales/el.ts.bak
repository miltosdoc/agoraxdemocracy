  'walkthrough.hiw_score_transparency': 'Διαφάνεια',
  'walkthrough.hiw_feature1_1': 'Καθαρή δομή: Ερώτημα + Λύση',
  'walkthrough.hiw_feature1_2': 'Κατηγοριοποίηση ανά θεματική',
  'walkthrough.hiw_feature1_3': 'Σύνδεση με κοινότητα πολιτών',
  'walkthrough.hiw_feature2_1': 'Σκορ 0-100 με διαφάνεια',
  'walkthrough.hiw_feature2_2': 'Τρεις ζώνες: Επιστροφής (<20), Κλήρωσης (20-90), Αυτόματη (>90)',
  'walkthrough.hiw_feature2_3': 'Διασφάλιση ποιότητας από την αρχή',
  'walkthrough.hiw_feature3_1': 'Τροπολογίες από την κοινότητα',
