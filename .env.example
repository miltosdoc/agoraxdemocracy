# ─── AgoraX local Docker/demo environment ───────────────────────────────────
# Copy to .env and replace all change-* values before any non-local deployment.

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=agorax
POSTGRES_USER=agorax
POSTGRES_PASSWORD=change-this-local-db-password
DATABASE_URL=postgresql://agorax:change-this-local-db-password@db:5432/agorax

# ─── Session & Auth ──────────────────────────────────────────────────────────
# Use long random values. Example: openssl rand -hex 32
JWT_SECRET=change-this-jwt-secret-32-plus-chars
SESSION_SECRET=change-this-session-secret-32-plus-chars
# Demo mode is convenient locally but must never be enabled in production.
DEMO_MODE=true

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ─── Ballot Validation Service ───────────────────────────────────────────────
BALLOT_SERVICE_URL=http://ballot-service:8000
SALT_KEY=change-this-ballot-salt-32-plus-chars

# ─── LLM Integration (optional - for proposal validation) ────────────────────
LLM_API_KEY=
LLM_API_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ─── OpenStreetMap Nominatim (optional, for reverse geocoding) ───────────────
NOMINATIM_API_KEY=

# ─── Ports (for docker-compose) ──────────────────────────────────────────────
DB_PORT=5432
API_PORT=3000
BALLOT_PORT=8000

# ─── Node.js ─────────────────────────────────────────────────────────────────
APP_ENV=local
NODE_ENV=production
