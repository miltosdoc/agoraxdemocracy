# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=agorax
POSTGRES_USER=agorax
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://agorax:changeme@db:5432/agorax

# ─── Session & Auth ──────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Ballot Validation Service ───────────────────────────────────────────────
BALLOT_SERVICE_URL=http://agorax_ballot:8000

# ─── LLM Integration (optional - for proposal validation) ────────────────────
LLM_API_KEY=
LLM_API_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# ─── OpenStreetMap Nominatim (optional, for reverse geocoding) ───────────────
NOMINATIM_API_KEY=

# ─── Ports (for docker-compose) ──────────────────────────────────────────────
DB_PORT=5432
API_PORT=3000
BALLOT_PORT=8000

# ─── Node.js ─────────────────────────────────────────────────────────────────
NODE_ENV=production