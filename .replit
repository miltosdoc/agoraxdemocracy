modules = ["nodejs-20", "postgresql-16"]
[userenv]

[userenv.shared]
PORT = "5000"
NODE_ENV = "development"
VOTING_BACKEND = "hash-chain"
LOG_LEVEL = "info"
SIGNING_MASTER_KEY = "a857c321fa5981f403a901c785f85e7b243c8d6b0cbbbf7b4f0e3969161718dc"
LIVEKIT_URL = "ws://localhost:7880"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "LiveKit Server"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "LiveKit Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "./livekit-server --config livekit.yaml"

[workflows.workflow.metadata]
outputType = "console"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80
