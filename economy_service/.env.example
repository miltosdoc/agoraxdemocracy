# Economy Service Configuration

# Database — shared PostgreSQL with main API and ballot_service
DATABASE_URL=postgresql://agorax:agorax@db:5432/agorax

# Stripe (leave empty to skip Stripe integration)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# BTCPay Server (leave empty to skip BTCPay)
BTCPAY_SERVER_URL=
BTCPAY_API_KEY=

# Exchange rate provider
COINGECKO_API_URL=https://api.coingecko.com/api/v3

# Admin secret (required for admin endpoints)
ADMIN_SECRET=

# Application settings
DEBUG=false
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
